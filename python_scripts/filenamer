#!/bin/bash
# Wrapper script to run filenamer.py with uv

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if Ollama is running, start it if not
if ! pgrep -x "ollama" > /dev/null; then
    echo "Ollama is not running. Starting Ollama..."
    if command -v ollama > /dev/null; then
        # Start Ollama in the background
        ollama serve > /dev/null 2>&1 &
        # Wait a moment for Ollama to start
        sleep 2
        echo "Ollama started."
    else
        echo "Error: Ollama is not installed. Please install it from https://ollama.com/download"
        exit 1
    fi
fi

# Convert all arguments to absolute paths
ARGS=()
for arg in "$@"; do
    if [[ -e "$arg" ]]; then
        # If the argument is an existing file or directory, convert to absolute path
        ARGS+=("$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")")
    elif [[ "$arg" == "." ]]; then
        # Special case for current directory
        ARGS+=("$(pwd)")
    else
        # Keep other arguments as-is
        ARGS+=("$arg")
    fi
done

cd "$SCRIPT_DIR"
exec uv run python filenamer.py "${ARGS[@]}"
